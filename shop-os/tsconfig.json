{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "declaration": false,
    "sourceMap": true,
    "strict": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": false,
    "allowJs": true
  },
  "include": [
    "./server.ts",
    "./api-server.ts",
    "./bot-worker.ts",
    "./job-worker.ts",
    "./src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../src",
    "../WAProto",
    "../WASignalGroup",
    "../Example",
    "../Tests"
  ]
}
